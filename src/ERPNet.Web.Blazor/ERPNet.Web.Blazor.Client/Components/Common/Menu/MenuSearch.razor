<div class="menu-search">
<ItemSelector TItem="MenuItem"
              SearchAsync="@BuscarAsync"
              GetLabel="@(m => m.Nombre)"
              GetHref="@(m => m.Path)"
              OnNavigate="@OnItemNavigate"
              Placeholder="Buscar en el menú... (Ctrl+K)"
              ShowSearchIcon="false"
              DebounceMs="100"
              DetachedDropdown="true"
              GlobalShortcutKey="k">
    <ItemTemplate Context="item">
        <i class="bi @(item.IconClass ?? "bi-dash") opacity-75 flex-shrink-0"></i>
        <span class="flex-grow-1 text-truncate">
            @if (item.Padre is not null)
            {
                <small class="text-secondary">@item.Padre / </small>
            }
            @item.Nombre
        </span>
    </ItemTemplate>
</ItemSelector>
</div>
