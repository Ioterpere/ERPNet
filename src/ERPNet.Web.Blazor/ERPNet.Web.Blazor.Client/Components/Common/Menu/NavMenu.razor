<div class="nav-menu d-flex flex-column h-100">
    <div class="top-row ps-3 navbar navbar-dark d-none d-md-flex">
        <div class="container-fluid">
            <a class="navbar-brand" href="">
                <img src="logo-clavo-blanco.png" alt="Clavo Food Factory" style="height:1.75rem" />
            </a>
        </div>
    </div>

    <div class="top-row navbar navbar-dark d-flex d-md-none align-items-center px-3">
        <a class="navbar-brand flex-grow-1" href="">
            <img src="logo-clavo-blanco.png" alt="Clavo Food Factory" style="height:1.75rem" />
        </a>
        <button type="button" class="btn btn-link text-white p-0" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-label="Cerrar menú">
            <i class="bi bi-x-lg fs-5"></i>
        </button>
    </div>

    <nav class="nav flex-column flex-nowrap flex-grow-1 overflow-y-auto overflow-x-hidden">
        <div class="nav-item px-3">
            <NavLink class="nav-link w-100 text-start d-flex align-items-center gap-2 border-0" href=""
                     Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2"></i>
                <span class="flex-grow-1">Inicio</span>
            </NavLink>
        </div>

        @if (_menus is null)
        {
            <div class="px-3 pt-2 opacity-50">
                <div class="placeholder-glow d-flex flex-column gap-2">
                    <span class="placeholder col-8 rounded"></span>
                    <span class="placeholder col-7 rounded"></span>
                    <span class="placeholder col-9 rounded"></span>
                </div>
            </div>
        }
        else
        {
            @foreach (var menu in _menus)
            {
                @if (menu.SubMenus?.Count > 0)
                {
                    <div class="nav-item px-3">
                        <button class="nav-link w-100 text-start d-flex align-items-center gap-2 border-0 bg-transparent"
                                @onclick="() => Toggle(menu.Id)">
                            @if (!string.IsNullOrEmpty(menu.IconClass))
                            {
                                <i class="bi @menu.IconClass"></i>
                            }
                            <span class="flex-grow-1">@menu.Nombre</span>
                            <i class="bi @(_expanded.Contains(menu.Id) ? "bi-chevron-up" : "bi-chevron-down") small opacity-75"></i>
                        </button>


                        @if (_expanded.Contains(menu.Id))
                        {
                            <div class="ps-3 ms-1 border-start border-secondary border-opacity-25">
                                @foreach (var sub in menu.SubMenus)
                                {
                                    @if (sub.SubMenus?.Count > 0)
                                    {
                                        <button class="nav-link py-1 w-100 text-start d-flex align-items-center gap-2 border-0 bg-transparent"
                                                @onclick="() => Toggle(sub.Id)">
                                            @if (!string.IsNullOrEmpty(sub.IconClass))
                                            {
                                                <i class="bi @sub.IconClass me-2 small"></i>
                                            }
                                            <span class="small flex-grow-1">@sub.Nombre</span>
                                            <i class="bi @(_expanded.Contains(sub.Id) ? "bi-chevron-up" : "bi-chevron-down") small opacity-75"></i>
                                        </button>
                                        @if (_expanded.Contains(sub.Id))
                                        {
                                            <div class="ps-3 ms-1 border-start border-secondary border-opacity-25">
                                                @foreach (var sub3 in sub.SubMenus)
                                                {
                                                    <NavLink class="nav-link py-1" href="@sub3.Path?.TrimStart('/')">
                                                        @if (!string.IsNullOrEmpty(sub3.IconClass))
                                                        {
                                                            <i class="bi @sub3.IconClass me-2 small"></i>
                                                        }
                                                        <span class="small">@sub3.Nombre</span>
                                                    </NavLink>
                                                }
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <NavLink class="nav-link py-1" href="@sub.Path?.TrimStart('/')">
                                            @if (!string.IsNullOrEmpty(sub.IconClass))
                                            {
                                                <i class="bi @sub.IconClass me-2 small"></i>
                                            }
                                            <span class="small">@sub.Nombre</span>
                                        </NavLink>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(menu.Path))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@menu.Path.TrimStart('/')">
                            @if (!string.IsNullOrEmpty(menu.IconClass))
                            {
                                <i class="bi @menu.IconClass me-2"></i>
                            }
                            @menu.Nombre
                        </NavLink>
                    </div>
                }
            }
        }
    </nav>

    <div class="border-top flex-shrink-0">
        @if (_cargandoEmpresas)
        {
            <div class="d-flex align-items-center gap-2 text-white small px-3 py-2 opacity-50">
                <span class="spinner-border spinner-border-sm flex-shrink-0" role="status" aria-hidden="true"></span>
                <span class="text-truncate">@(_empresaActualNombre ?? "Cargando...")</span>
            </div>
        }
        else if (_empresas.Count > 1)
        {
            <div class="dropup px-3 py-2">
                <button class="btn btn-link text-white text-decoration-none p-0 w-100 text-start d-flex align-items-center gap-2 dropdown-toggle"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-building-fill flex-shrink-0"></i>
                    <span class="text-truncate small flex-grow-1">@_empresaActualNombre</span>
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Cambiar empresa</h6></li>
                    @foreach (var empresa in _empresas)
                    {
                        <li>
                            <button class="dropdown-item @(empresa.Id == _empresaActualId ? "active" : "")"
                                    @onclick="() => CambiarEmpresaAsync(empresa.Id)"
                                    disabled="@(empresa.Id == _empresaActualId)">
                                <i class="bi bi-building me-2"></i>@empresa.Nombre
                            </button>
                        </li>
                    }
                </ul>
            </div>
        }
        else if (_empresaActualNombre is not null)
        {
            <div class="d-flex align-items-center gap-2 text-white small px-3 py-2 opacity-75">
                <i class="bi bi-building-fill flex-shrink-0"></i>
                <span class="text-truncate">@_empresaActualNombre</span>
            </div>
        }
    </div>
</div>
