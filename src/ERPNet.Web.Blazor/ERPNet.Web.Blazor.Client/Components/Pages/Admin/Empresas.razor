@page "/empresas"
@inherits ErpPageBase

<ErpPage @ref="_refLayout"
               Titulo="Empresas"
               TituloNuevo="Nueva empresa"
               EsNuevo="_esNuevo"
               TieneDetalle="Id.HasValue"
               Busqueda="@_busqueda"
               OnBusquedaInput="OnBusquedaInputAsync"
               OnNuevo="OnNuevo"
               OnVolverALista="VolverALista"
               ColLista="3"
               SearchPlaceholder="Buscar por nombre..."
               PlaceholderIcono="bi-building"
               PlaceholderTexto="Selecciona una empresa de la lista"
               TotalItems="_totalItems"
               @bind-MostrarModalEliminar="_mostrarModalEliminar"
               TextoEliminar="@($"la empresa {_empresaDetalle?.Nombre}")"
               ErrorEliminar="@_errorEliminar"
               Eliminando="_eliminando"
               OnEliminar="EliminarEmpresaAsync">

    <ListaBody>
        <VirtualList @ref="_refLista" TItem="EmpresaResponse"
                    IconoVacio="bi-building-x"
                    ItemsProvider="CargarItemsAsync"
                    OnTotalChanged="t => _totalItems = t">
            <SkeletonItem>
                <div class="rol-row placeholder-glow">
                    <span class="placeholder col-6 d-block mb-1" style="height:13px"></span>
                    <span class="placeholder col-4" style="height:11px"></span>
                </div>
            </SkeletonItem>
            <ItemTemplate Context="e">
                <button type="button"
                        class="rol-row w-100 text-start @(Id == e.Id ? "active" : "")"
                        @onclick="() => SeleccionarItem(e.Id)">
                    <div class="d-flex align-items-center gap-2">
                        <div class="fw-semibold text-truncate small flex-grow-1">@e.Nombre</div>
                        @if (!e.Activo)
                        {
                            <span class="badge bg-secondary-subtle text-secondary-emphasis" style="font-size:.65rem">Inactiva</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(e.Cif))
                    {
                        <div class="text-muted text-truncate" style="font-size:.75rem">@e.Cif</div>
                    }
                </button>
            </ItemTemplate>
        </VirtualList>
    </ListaBody>

    <FormNuevo>
        @if (_errorCrear is not null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                <span>@_errorCrear</span>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-building-add text-primary"></i>
                <span class="fw-semibold">Datos de la empresa</span>
            </div>
            <div class="card-body py-4">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @ref="_refNuevoNombre" @bind="_nuevoNombre"
                               placeholder="Nombre de la empresa" autocomplete="off" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">CIF</label>
                        <input type="text" class="form-control" @bind="_nuevoCif"
                               placeholder="Ej: A12345678" autocomplete="off" />
                    </div>
                    <div class="col-12 col-md-6 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="nuevoActivo" @bind="_nuevoActivo" />
                            <label class="form-check-label" for="nuevoActivo">Activa</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <button class="btn btn-outline-secondary btn-sm" @onclick="VolverALista">Cancelar</button>
            <button class="btn btn-primary" @onclick="CrearEmpresaAsync" disabled="@_creando">
                @if (_creando)
                {
                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-building-check me-1"></i>
                }
                Crear empresa
            </button>
        </div>
    </FormNuevo>

    <FormEdicion>
        <div class="px-4 py-4">

            <div class="d-flex align-items-center gap-3 mb-4">
                <button class="btn btn-sm btn-light d-lg-none" @onclick="VolverALista">
                    <i class="bi bi-arrow-left"></i>
                </button>

                @if (_cargandoDetalle)
                {
                    <div class="d-flex align-items-center gap-3 placeholder-glow flex-grow-1">
                        <div>
                            <span class="placeholder d-block mb-1" style="height:14px;width:160px"></span>
                            <span class="placeholder" style="height:11px;width:100px"></span>
                        </div>
                    </div>
                }
                else if (_empresaDetalle is not null)
                {
                    <div class="flex-grow-1 overflow-hidden">
                        <h5 class="mb-0 fw-semibold text-truncate">@_empresaDetalle.Nombre</h5>
                        @if (!string.IsNullOrWhiteSpace(_empresaDetalle.Cif))
                        {
                            <p class="text-muted small mb-0">@_empresaDetalle.Cif</p>
                        }
                    </div>
                    @if (!_empresaDetalle.Activo)
                    {
                        <span class="badge bg-secondary">Inactiva</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success-emphasis">Activa</span>
                    }
                }
            </div>

            @if (_errorDetalle is not null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                    <span>@_errorDetalle</span>
                </div>
            }

            @if (!_cargandoDetalle && _empresaDetalle is not null)
            {
                <div class="card mb-4">
                    <div class="card-header d-flex align-items-center gap-2">
                        <i class="bi bi-pencil text-primary"></i>
                        <span class="fw-semibold">Datos de la empresa</span>
                    </div>
                    <div class="card-body py-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Nombre <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="_editNombre" autocomplete="off" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">CIF</label>
                                <input type="text" class="form-control" @bind="_editCif" autocomplete="off" />
                            </div>
                            <div class="col-12 col-md-6 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="editActivo" @bind="_editActivo" />
                                    <label class="form-check-label" for="editActivo">Activa</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </FormEdicion>

    <DetailToolbar>
        @if (!_cargandoDetalle && _empresaDetalle is not null)
        {
            <button class="btn btn-outline-danger me-auto"
                    @onclick="AbrirModalEliminar">
                <i class="bi bi-trash3 me-1"></i>Eliminar empresa
            </button>
            @if (_errorGuardar is not null)
            {
                <span class="text-danger small me-2 d-flex align-items-center gap-1">
                    <i class="bi bi-x-circle-fill"></i>@_errorGuardar
                </span>
            }
            <button class="btn btn-primary" @onclick="OnGuardar" disabled="@_guardando">
                @if (_guardando)
                {
                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                }
                Guardar cambios
            </button>
        }
    </DetailToolbar>

</ErpPage>

