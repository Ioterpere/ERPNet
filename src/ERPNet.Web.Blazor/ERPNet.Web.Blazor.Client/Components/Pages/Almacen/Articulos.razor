@page "/articulos"
@inherits ErpPageBase

<ErpPage @ref="_refLayout"
               ConTabs="true"
               Titulo="Artículos"
               TituloNuevo="Nuevo artículo"
               EsNuevo="_esNuevo"
               TieneDetalle="Id.HasValue"
               Busqueda="@_busqueda"
               OnBusquedaInput="OnBusquedaInputAsync"
               OnNuevo="OnNuevo"
               OnVolverALista="VolverALista"
               ColLista="4"
               SearchPlaceholder="Código, descripción"
               PlaceholderIcono="bi-tags"
               PlaceholderTexto="Selecciona un artículo de la lista"
               PlaceholderSubTexto='@("o crea uno nuevo con el botón &quot;+ Nuevo&quot;")'
               TotalItems="_totalItems"
               @bind-MostrarModalEliminar="_mostrarModalEliminar"
               TextoEliminar="@($"el artículo {_articuloDetalle?.Codigo}")"
               ErrorEliminar="@_errorEliminar"
               Eliminando="_eliminando"
               OnEliminar="EliminarArticuloAsync">

    <ListaBody>
        <VirtualList @ref="_refLista" TItem="ArticuloResponse"
                    IconoVacio="bi-tags"
                    ItemsProvider="CargarItemsAsync"
                    ItemSize="26"
                    OnTotalChanged="t => _totalItems = t">
            <SkeletonItem>
                <div class="art-row placeholder-glow">
                    <span class="placeholder art-codigo-col" style="height:11px;border-radius:2px"></span>
                    <span class="placeholder flex-grow-1 ms-2" style="height:11px;border-radius:2px"></span>
                </div>
            </SkeletonItem>
            <ItemTemplate Context="a">
                <button type="button"
                        class="art-row w-100 text-start @(Id == a.Id ? "active" : "")"
                        @onclick="() => SeleccionarItem(a.Id)">
                    <span class="art-codigo-col font-monospace">@a.Codigo</span>
                    <span class="art-desc flex-grow-1 text-truncate text-uppercase">@a.Descripcion</span>
                    @if (_ordenarPor == nameof(ArticuloResponse.FamiliaArticuloNombre))
                    {
                        <span class="art-meta">@a.FamiliaArticuloNombre</span>
                    }
                    else if (_ordenarPor == nameof(ArticuloResponse.PrecioCoste))
                    {
                        <span class="art-meta font-monospace">@a.PrecioCoste.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-ES")) €</span>
                    }
                    else if (_ordenarPor == nameof(ArticuloResponse.PrecioVenta))
                    {
                        <span class="art-meta font-monospace">@a.PrecioVenta.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-ES")) €</span>
                    }
                    @if (a.EsObsoleto)
                    {
                        <span class="art-pill obs">OBS</span>
                    }
                    @if (a.EsNuevo)
                    {
                        <span class="art-pill new">NEW</span>
                    }
                </button>
            </ItemTemplate>
        </VirtualList>
    </ListaBody>

    <ListaFooterExtra>
        <div class="d-flex align-items-center gap-1">
            <button class="btn btn-link btn-sm text-muted p-0" type="button"
                    @onclick="ToggleOrdenDescAsync" title="@(_ordenDesc ? "Descendente" : "Ascendente")"
                    style="font-size:.8rem; box-shadow:none">
                <i class="bi @(_ordenDesc ? "bi-sort-alpha-up" : "bi-sort-alpha-down")"></i>
            </button>
            <div class="dropdown">
                <button class="btn btn-link btn-sm text-muted text-decoration-none dropdown-toggle p-0"
                        type="button" data-bs-toggle="dropdown" style="font-size:.75rem; box-shadow:none">
                    @_camposOrden.First(c => c.Valor == _ordenarPor).Label
                </button>
                <ul class="dropdown-menu dropdown-menu-start shadow-sm">
                    @foreach (var campo in _camposOrden)
                    {
                        <li>
                            <button class="dropdown-item small" type="button" @onclick="() => SetOrdenAsync(campo.Valor)">
                                <i class="bi bi-check me-2 @(_ordenarPor == campo.Valor ? "" : "invisible")"></i>@campo.Label
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </ListaFooterExtra>

    <FormNuevo>
        @if (_errorCrear is not null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                <span>@_errorCrear</span>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-tag text-primary"></i>
                <span class="fw-semibold">Datos básicos</span>
            </div>
            <div class="card-body py-4">
                <div class="row g-3">
                    <div class="col-sm-4">
                        <label class="form-label">Código <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" @ref="_refNuevoCodigo"
                               @bind="_nuevoCodigo" placeholder="ART-001" autocomplete="off" />
                    </div>
                    <div class="col-sm-8">
                        <label class="form-label">Descripción <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_nuevDescripcion"
                               placeholder="Nombre del artículo" autocomplete="off" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">Unidad de medida</label>
                        <input type="text" class="form-control font-monospace text-uppercase" @bind="_nuevUnidadMedida"
                               placeholder="KG" autocomplete="off" maxlength="20" />
                    </div>
                    <div class="col-sm-8">
                        <label class="form-label">Familia</label>
                        <select class="form-select" @bind="_nuevFamiliaId">
                            <option value="0">-- Sin familia --</option>
                            @foreach (var f in _familias)
                            {
                                <option value="@f.Id">@f.Nombre</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary px-4" @onclick="CrearArticuloAsync" disabled="@_creando">
                @if (_creando)
                {
                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-check-lg me-2"></i>
                }
                Crear artículo
            </button>
            <button class="btn btn-outline-secondary" @onclick="VolverALista">Cancelar</button>
        </div>
    </FormNuevo>

    <FormEdicion>
        <div class="px-3 py-2 flex-shrink-0">

            <!-- Header de detalle -->
            <div class="d-flex align-items-center gap-2 mb-2">
                <button class="btn btn-sm btn-light d-lg-none" @onclick="VolverALista">
                    <i class="bi bi-arrow-left"></i>
                </button>

                @if (_cargandoDetalle)
                {
                    <div class="placeholder-glow flex-grow-1">
                        <span class="placeholder d-block mb-1" style="height:13px;width:100px"></span>
                        <span class="placeholder" style="height:10px;width:180px"></span>
                    </div>
                }
                else if (_articuloDetalle is not null)
                {
                    <div class="flex-grow-1 overflow-hidden d-flex align-items-baseline gap-2">
                        <span class="fw-semibold font-monospace" style="font-size:.95rem">@_articuloDetalle.Codigo</span>
                        <span class="text-muted text-truncate small text-uppercase">@_articuloDetalle.Descripcion</span>
                        @if (_articuloDetalle.EsObsoleto)
                        {
                            <span class="art-pill obs flex-shrink-0">OBS</span>
                        }
                        @if (_articuloDetalle.EsNuevo)
                        {
                            <span class="art-pill new flex-shrink-0">NEW</span>
                        }
                    </div>
                }
            </div>

            @if (_errorDetalle is not null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-2 py-2">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                    <span>@_errorDetalle</span>
                </div>
            }

        </div>

        @if (!_cargandoDetalle && _articuloDetalle is not null)
        {
            <Tabs Items="_tabsArticulo" ActiveTab="@(Tab ?? "datos")" ActiveTabChanged="CambiarTab">

                <!-- ── Tab: Datos ────────────────────────────────────── -->
                @if ((Tab ?? "datos") == "datos")
                {
                    <!-- Card 1: Ficha -->
                    <div class="card mb-2">
                        <div class="card-header-compact d-flex align-items-center gap-2">
                            <i class="bi bi-tag text-primary" style="font-size:.8rem"></i>
                            <span class="label-section">Ficha</span>
                        </div>
                        <div class="card-body px-3 py-2">
                            <div class="row g-2">
                                <div class="col-3 col-xl-2">
                                    <label class="form-label-sm">Código</label>
                                    <input type="text" class="form-control form-control-sm font-monospace"
                                           @bind="_editCodigo" />
                                </div>
                                <div class="col-2">
                                    <label class="form-label-sm">U. medida</label>
                                    <input type="text" class="form-control form-control-sm font-monospace text-uppercase"
                                           @bind="_editUnidadMedida" maxlength="20" />
                                </div>
                                <div class="col-2">
                                    <label class="form-label-sm">U. medida 2</label>
                                    <input type="text" class="form-control form-control-sm font-monospace text-uppercase"
                                           @bind="_editUnidadMedida2" maxlength="3" />
                                </div>
                                <div class="col-5 col-xl-6">
                                    <label class="form-label-sm">Código de barras</label>
                                    <input type="text" class="form-control form-control-sm font-monospace"
                                           @bind="_editCodigoBarras" maxlength="13" />
                                </div>

                                <div class="col-8">
                                    <label class="form-label-sm">Descripción</label>
                                    <input type="text" class="form-control form-control-sm"
                                           @bind="_editDescripcion" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Familia</label>
                                    <select class="form-select form-select-sm" @bind="_editFamiliaId">
                                        <option value="0">—</option>
                                        @foreach (var f in _familias)
                                        {
                                            <option value="@f.Id">@f.Nombre</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-8">
                                    <label class="form-label-sm">Descripción de venta</label>
                                    <input type="text" class="form-control form-control-sm"
                                           @bind="_editDescripcionVenta" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Tipo de IVA</label>
                                    <select class="form-select form-select-sm" @bind="_editTipoIvaId">
                                        <option value="0">—</option>
                                        @foreach (var t in _tiposIva)
                                        {
                                            <option value="@t.Id">@t.Nombre (@t.Porcentaje %)</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-8">
                                    <label class="form-label-sm">Proveedor principal</label>
                                    <input type="text" class="form-control form-control-sm"
                                           @bind="_editProveedorPrincipal" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Formato</label>
                                    <select class="form-select form-select-sm" @bind="_editFormatoId">
                                        <option value="0">—</option>
                                        @foreach (var fo in _formatos)
                                        {
                                            <option value="@fo.Id">@fo.Nombre</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label class="form-label-sm">Config. caducidad</label>
                                    <select class="form-select form-select-sm" @bind="_editCaducidadId">
                                        <option value="0">— Sin configurar —</option>
                                        @foreach (var c in _configuracionesCaducidad)
                                        {
                                            <option value="@c.Id">@c.Nombre (@c.DiasAviso días)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2: Precios y stock -->
                    <div class="card mb-2">
                        <div class="card-header-compact d-flex align-items-center gap-2">
                            <i class="bi bi-currency-euro text-primary" style="font-size:.8rem"></i>
                            <span class="label-section">Precios y stock</span>
                        </div>
                        <div class="card-body px-3 py-2">
                            <div class="row g-2">
                                <div class="col-4">
                                    <label class="form-label-sm">Precio coste</label>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control text-end font-monospace"
                                               value="@FormatPrecio(_editPrecioCoste)"
                                               @onchange="e => _editPrecioCoste = ParsePrecio(e.Value?.ToString())" />
                                        <span class="input-group-text">€</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Precio medio</label>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control text-end font-monospace"
                                               value="@FormatPrecio(_editPrecioMedio)"
                                               @onchange="e => _editPrecioMedio = ParsePrecio(e.Value?.ToString())" />
                                        <span class="input-group-text">€</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Precio venta</label>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control text-end font-monospace"
                                               value="@FormatPrecio(_editPrecioVenta)"
                                               @onchange="e => _editPrecioVenta = ParsePrecio(e.Value?.ToString())" />
                                        <span class="input-group-text">€</span>
                                    </div>
                                </div>

                                <div class="col-12"><hr class="my-1" /></div>

                                <div class="col-4">
                                    <label class="form-label-sm">Stock mínimo</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="0.001" min="0" @bind="_editStockMinimo" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Nivel de pedido</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="0.001" min="0" @bind="_editNivelPedido" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Nivel de reposición</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="0.001" min="0" @bind="_editNivelReposicion" />
                                </div>

                                <div class="col-4">
                                    <label class="form-label-sm">Uds/caja</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="0.001" min="0" @bind="_editUnidadesCaja" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Uds/palé</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="1" min="0" @bind="_editUnidadesPalet" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label-sm">Filas/palé</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="1" min="0" @bind="_editFilasPalet" />
                                </div>

                                <div class="col-3">
                                    <label class="form-label-sm">Peso (g)</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="0.1" min="0" @bind="_editPesoGramo" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label-sm">Lead time (días)</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="1" min="0" @bind="_editLeadTime" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label-sm">Días vida útil</label>
                                    <input type="number" class="form-control form-control-sm"
                                           step="1" min="0" @bind="_editDiasVidaUtil" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label-sm">Depreciación</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control"
                                               step="0.01" min="0" max="100" @bind="_editDepreciacion" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3: Indicadores + Observaciones -->
                    <div class="card mb-2">
                        <div class="card-body px-3 py-2">
                            <div class="d-flex flex-wrap gap-3 mb-2">
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="chk-inventariable"
                                           @bind="_editEsInventariable" />
                                    <label class="form-check-label small" for="chk-inventariable">Inventariable</label>
                                </div>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="chk-propio"
                                           @bind="_editEsPropio" />
                                    <label class="form-check-label small" for="chk-propio">Propio</label>
                                </div>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="chk-nuevo"
                                           @bind="_editEsNuevo" />
                                    <label class="form-check-label small" for="chk-nuevo">Nuevo</label>
                                </div>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="chk-obsoleto"
                                           @bind="_editEsObsoleto" />
                                    <label class="form-check-label small" for="chk-obsoleto">Obsoleto</label>
                                </div>
                            </div>
                            <textarea class="form-control form-control-sm" rows="2"
                                      placeholder="Observaciones..." @bind="_editObservaciones"></textarea>
                        </div>
                    </div>
                }

                <!-- ── Tab: C. Facturación ──────────────────────────── -->
                @if ((Tab ?? "datos") == "facturacion")
                {
                    <div class="text-muted p-4 text-center fst-italic">C. Facturación — pendiente de implementar</div>
                }

                <!-- ── Tab: Tpo. Pallet ──────────────────────────────── -->
                @if ((Tab ?? "datos") == "pallet")
                {
                    <div class="text-muted p-4 text-center fst-italic">Tpo. Pallet — pendiente de implementar</div>
                }

                <!-- ── Tab: DPR ──────────────────────────────────────── -->
                @if ((Tab ?? "datos") == "dpr")
                {
                    <div class="text-muted p-4 text-center fst-italic">DPR — pendiente de implementar</div>
                }

                <!-- ── Tab: Geo. Movimiento ───────────────────────────── -->
                @if ((Tab ?? "datos") == "movimiento")
                {
                    <div class="text-muted p-4 text-center fst-italic">Geo. Movimiento — pendiente de implementar</div>
                }

                <!-- ── Tab: Tpo. Rappel ───────────────────────────────── -->
                @if ((Tab ?? "datos") == "rappel")
                {
                    <div class="text-muted p-4 text-center fst-italic">Tpo. Rappel — pendiente de implementar</div>
                }

                <!-- ── Tab: Calidad ───────────────────────────────────── -->
                @if ((Tab ?? "datos") == "calidad")
                {
                    <div class="text-muted p-4 text-center fst-italic">Calidad — pendiente de implementar</div>
                }

                <!-- ── Tab: Log ──────────────────────────────────────── -->
                @if ((Tab ?? "datos") == "log")
                {
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center gap-2">
                            <i class="bi bi-journal-text text-primary"></i>
                            <span class="fw-semibold">Nueva entrada de log</span>
                        </div>
                        <div class="card-body py-3">
                            @if (_errorLog is not null)
                            {
                                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3">
                                    <i class="bi bi-x-circle-fill flex-shrink-0"></i>
                                    <span>@_errorLog</span>
                                </div>
                            }
                            <div class="row g-2">
                                <div class="col-sm-3">
                                    <label class="form-label small">Fecha</label>
                                    <input type="date" class="form-control form-control-sm"
                                           @bind="_nuevoLogFecha" />
                                </div>
                                <div class="col-sm-3">
                                    <label class="form-label small">Stock anterior</label>
                                    <input type="number" class="form-control form-control-sm"
                                           @bind="_nuevoLogStockAnterior" step="0.001" />
                                </div>
                                <div class="col-sm-3">
                                    <label class="form-label small">Stock nuevo</label>
                                    <input type="number" class="form-control form-control-sm"
                                           @bind="_nuevoLogStockNuevo" step="0.001" />
                                </div>
                                <div class="col-sm-9">
                                    <label class="form-label small">Nota <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm"
                                           @bind="_nuevoLogNota" placeholder="Descripción del movimiento" />
                                </div>
                                <div class="col-sm-3 d-flex align-items-end">
                                    <button class="btn btn-sm btn-primary w-100" @onclick="GuardarLogAsync"
                                            disabled="@_guardandoLog">
                                        @if (_guardandoLog)
                                        {
                                            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-plus-lg me-1"></i>
                                        }
                                        Añadir
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-list-ul text-primary"></i>
                                <span class="fw-semibold">Historial</span>
                            </div>
                            @if (_logs.Count > 0)
                            {
                                <span class="badge bg-primary-subtle text-primary-emphasis">@_logs.Count</span>
                            }
                        </div>
                        <div class="card-body p-0">
                            @if (_cargandoLogs)
                            {
                                <div class="p-4 text-center text-muted">
                                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                                    Cargando...
                                </div>
                            }
                            else if (_logs.Count == 0)
                            {
                                <div class="p-4 text-center text-muted small">
                                    <i class="bi bi-journal-x d-block fs-4 mb-1"></i>
                                    Sin entradas de log
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="ps-3 small">Fecha</th>
                                                <th class="small">Nota</th>
                                                <th class="text-end small">Stock ant.</th>
                                                <th class="text-end small pe-3">Stock nuevo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var log in _logs)
                                            {
                                                <tr>
                                                    <td class="ps-3 small text-nowrap">@log.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td class="small">
                                                        <div class="text-truncate" style="max-width:260px">@log.Nota</div>
                                                        @if (log.UsuarioNombre is not null)
                                                        {
                                                            <div class="text-muted" style="font-size:.7rem">@log.UsuarioNombre</div>
                                                        }
                                                    </td>
                                                    <td class="text-end small font-monospace">@log.StockAnterior?.ToString("N2")</td>
                                                    <td class="text-end small font-monospace pe-3">@log.StockNuevo?.ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                }

            </Tabs>
        }
    </FormEdicion>

    <DetailToolbar>
        @if (!_cargandoDetalle && _articuloDetalle is not null)
        {
            <button class="btn btn-outline-danger me-auto" @onclick="AbrirModalEliminar">
                <i class="bi bi-trash3 me-1"></i>Eliminar artículo
            </button>
            @if ((Tab ?? "datos") == "datos")
            {
                @if (_errorGuardar is not null)
                {
                    <span class="text-danger small me-auto d-flex align-items-center gap-1">
                        <i class="bi bi-x-circle-fill"></i>@_errorGuardar
                    </span>
                }
                <button class="btn btn-primary" @onclick="GuardarDatosAsync" disabled="@_guardando">
                    @if (_guardando)
                    {
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                    }
                    Guardar cambios
                </button>
            }
        }
    </DetailToolbar>

</ErpPage>
