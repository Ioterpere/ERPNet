@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar @(_sidebarCollapsed ? "sidebar-collapsed" : "") offcanvas-md offcanvas-start" tabindex="-1"
         id="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @* icono del sidebar en la versión movil *@
            <button class="btn btn-link text-white p-0 d-md-none" type="button" data-bs-toggle="offcanvas"
                    data-bs-target="#sidebar">
                <i class="bi bi-list fs-4"></i>
            </button>

            <button class="btn btn-link text-white p-0 d-none d-md-flex align-items-center" @onclick="ToggleSidebar">
                <i class="bi bi-list fs-4"></i>
            </button>

            <a class="navbar-brand text-white m-0 d-md-none" href="">
                <i class="bi bi-box-seam-fill me-2"></i>ERP<span>Net</span>
            </a>

            <div class="top-row-details d-none d-sm-flex align-items-center gap-2">
                @if (_empresaNombre is not null)
                {
                    <span class="vr opacity-25 my-1"></span>
                    @if (EmpresaState.Empresas.Count > 1)
                    {
                        <div class="dropdown d-none d-md-flex align-items-center">
                            <button class="btn btn-link text-white text-decoration-none p-0 d-flex align-items-center gap-2 dropdown-toggle top-row-empresa-btn"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-building-fill"></i>
                                <span>@_empresaNombre</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">Cambiar empresa</h6></li>
                                @foreach (var empresa in EmpresaState.Empresas)
                                {
                                    <li>
                                        <button class="dropdown-item @(empresa.Id == EmpresaState.EmpresaId ? "active" : "")"
                                                type="button"
                                                @onclick="() => CambiarEmpresaAsync(empresa.Id)"
                                                disabled="@(empresa.Id == EmpresaState.EmpresaId)">
                                            <i class="bi bi-building me-2"></i>@empresa.Nombre
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="top-row-empresa d-flex gap-2">
                            <i class="bi bi-building-fill"></i>
                            <span>@_empresaNombre</span>
                        </div>
                    }
                }
                <span class="vr opacity-25 my-1"></span>
                <div class="top-row-search flex-grow-1">
                    <MenuSearch />
                </div>
            </div>


            @if (_tieneAsistenteIa)
            {
                <button class="btn btn-link text-white p-0 me-2 d-none d-md-flex align-items-center" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#chat-offcanvas"
                        title="Asistente IA (Ctrl+Shift+A)">
                    <i class="bi bi-robot fs-5"></i>
                </button>
            }

            <div class="dropdown">
                <button
                    class="btn btn-link text-white text-decoration-none dropdown-toggle p-0 d-flex align-items-center gap-2"
                    type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle fs-5"></i>
                    @if (_email is not null)
                    {
                        <span class="d-none d-sm-inline" style="font-size:.875rem">@_email</span>
                    }
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/account"><i class="bi bi-person me-2"></i>Mi perfil</a>
                    </li>
                    @if (_tieneAsistenteIa)
                    {
                        <li class="d-md-none">
                            <button class="dropdown-item" type="button"
                                    data-bs-toggle="offcanvas" data-bs-target="#chat-offcanvas">
                                <i class="bi bi-robot me-2"></i>Asistente IA
                            </button>
                        </li>
                    }
                    <li>
                        <hr class="dropdown-divider" />
                    </li>
                    <li>
                        <form method="post" action="/bff/logout">
                            <button type="submit" class="dropdown-item">
                                <i class="bi bi-box-arrow-right me-2"></i>
                                Cerrar sesión
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

<ToastContainer />

@if (_tieneAsistenteIa)
{
<div class="offcanvas offcanvas-end" tabindex="-1" id="chat-offcanvas"
     aria-labelledby="chat-offcanvas-label"
     style="width: min(420px, 100vw)">
    <div class="offcanvas-header" style="background-color: var(--bs-primary); color: #fff;">
        <h6 class="offcanvas-title mb-0 d-flex align-items-center gap-2" id="chat-offcanvas-label">
            <i class="bi bi-robot me-2"></i>Asistente IA
            @if (_herramientas is { Count: > 0 })
            {
                <span class="ai-info" tabindex="0">
                    <i class="bi bi-info-circle-fill opacity-50" style="font-size:.8rem"></i>
                    <span class="ai-info-tooltip">
                        @foreach (var h in _herramientas!)
                        {
                            <div>@h</div>
                        }
                    </span>
                </span>
            }
        </h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"
                aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body p-0" style="display:flex; flex-direction:column; overflow:hidden;">
        <ChatPanel />
    </div>
</div>
}

<div id="blazor-error-ui" data-nosnippet>
    Se produjo un error inesperado
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>
