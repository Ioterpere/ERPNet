@typeparam TItem
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="item-selector" @onfocusout="OnFocusOut">

    @if (_itemSeleccionado is not null && !OnNavigate.HasDelegate)
    {
        <!-- Modo seleccionado -->
        <div class="input-group">
            <span class="input-group-text bg-transparent border-end-0 text-success-emphasis">
                <i class="bi bi-check-circle-fill"></i>
            </span>
            <span class="form-control border-start-0 item-selector-selected d-flex align-items-center gap-2 overflow-hidden">
                <span class="flex-grow-1 text-truncate fw-medium">@GetLabel(_itemSeleccionado)</span>
                @if (GetSubLabel?.Invoke(_itemSeleccionado) is { Length: > 0 } subSel)
                {
                    <span class="item-selector-item-sub text-truncate">@subSel</span>
                }
            </span>
            @if (!Disabled)
            {
                <button type="button" class="btn btn-outline-secondary" @onclick="Limpiar" tabindex="-1">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    }
    else
    {
        <!-- Modo búsqueda -->
        <div class="input-group">
            @if (ShowSearchIcon)
            {
                <span class="input-group-text bg-transparent border-end-0">
                    @if (_buscando)
                    {
                        <span class="spinner-border spinner-border-sm text-muted" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-search text-muted"></i>
                    }
                </span>
            }
            <input type="search"
                   class="form-control @(ShowSearchIcon ? "border-start-0 ps-0" : "")"
                   placeholder="@Placeholder"
                   value="@_query"
                   @oninput="OnInput"
                   @onfocus="OnFocus"
                   @onkeydown="OnKeyDown"
                   @ref="_inputRef"
                   disabled="@Disabled"
                   autocomplete="off" />
        </div>

        @if (_abierto)
        {
            <div class="item-selector-dropdown @(DetachedDropdown ? "detached" : "")" @onmousedown:preventDefault>
                @if (_buscando)
                {
                    <div class="item-selector-mensaje text-muted">
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                        Buscando...
                    </div>
                }
                else if (_sinResultados)
                {
                    <div class="item-selector-mensaje text-muted">
                        <i class="bi bi-search me-1"></i>Sin resultados para "<em>@_query</em>"
                    </div>
                }
                else
                {
                    @for (int i = 0; i < _resultados.Count; i++)
                    {
                        var item = _resultados[i];
                        var index = i;
                        <button type="button"
                                id="@($"{_id}-{index}")"
                                class="item-selector-item @(index == _indiceActivo ? "activo" : "")"
                                @onclick="() => Seleccionar(item)"
                                @onmouseenter="() => _indiceActivo = index">
                            @if (ItemTemplate is not null)
                            {
                                @ItemTemplate(item)
                            }
                            else
                            {
                                <span class="item-selector-item-label">@GetLabel(item)</span>
                                @if (GetSubLabel?.Invoke(item) is { Length: > 0 } subItem)
                                {
                                    <span class="item-selector-item-sub">@subItem</span>
                                }
                            }
                            @if (index == _indiceActivo)
                            {
                                <kbd class="item-selector-kbd ms-auto">↵</kbd>
                            }
                        </button>
                    }
                }
            </div>
        }
    }

</div>

@code {
    /// <summary>Función que recibe la query normalizada y devuelve los items coincidentes.</summary>
    [Parameter, EditorRequired]
    public Func<string, CancellationToken, Task<IEnumerable<TItem>>> SearchAsync { get; set; } = null!;

    /// <summary>Extrae el identificador (int) del item. Requerido cuando se usa Value/ValueChanged; no necesario en modo navegación.</summary>
    [Parameter]
    public Func<TItem, int>? GetId { get; set; }

    /// <summary>Texto principal que se muestra en el dropdown y en el chip de selección.</summary>
    [Parameter, EditorRequired]
    public Func<TItem, string> GetLabel { get; set; } = null!;

    /// <summary>Texto secundario opcional (p. ej. DNI, código).</summary>
    [Parameter]
    public Func<TItem, string?>? GetSubLabel { get; set; }

    /// <summary>Plantilla personalizada para cada item del dropdown. Sustituye a GetLabel/GetSubLabel en el listado.</summary>
    [Parameter]
    public RenderFragment<TItem>? ItemTemplate { get; set; }

    /// <summary>
    /// Callback invocado al seleccionar un item en modo navegación.
    /// Cuando está definido no se muestra el chip de seleccionado y el estado se limpia tras cada selección.
    /// </summary>
    [Parameter]
    public EventCallback<TItem> OnNavigate { get; set; }

    /// <summary>Valor actual (id del item seleccionado). Solo para modo selección.</summary>
    [Parameter]
    public int? Value { get; set; }

    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "Buscar...";

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>Muestra el icono de lupa (y el spinner de carga) a la izquierda del input. Default true.</summary>
    [Parameter]
    public bool ShowSearchIcon { get; set; } = true;

    /// <summary>Milisegundos de debounce antes de lanzar la búsqueda. 0 para búsqueda inmediata (datos locales).</summary>
    [Parameter]
    public int DebounceMs { get; set; } = 280;

    /// <summary>
    /// Cuando es true, el dropdown se separa del input con un hueco y bordes completamente redondeados.
    /// Útil fuera de formularios (p. ej. en la barra superior).
    /// </summary>
    [Parameter]
    public bool DetachedDropdown { get; set; }

    /// <summary>Tecla (junto a Ctrl) que enfoca este input desde cualquier parte de la página. Ej: "k" → Ctrl+K.</summary>
    [Parameter]
    public string? GlobalShortcutKey { get; set; }

    /// <summary>
    /// Item preseleccionado externamente.
    /// Se aplica al montar el componente; usa @key en el padre para forzar remount.
    /// </summary>
    [Parameter]
    public TItem? PreselectedItem { get; set; }

    private readonly string _id = $"isd-{Guid.NewGuid():N}";
    private ElementReference _inputRef;

    private TItem? _itemSeleccionado;
    private List<TItem> _resultados = [];
    private string _query = string.Empty;
    private bool _abierto;
    private bool _buscando;
    private bool _sinResultados;
    private CancellationTokenSource? _cts;

    private int _indiceActivo = -1;
    private bool _debeScrollar;
    private bool _keysRegistered;
    private bool _globalShortcutRegistered;

    protected override void OnInitialized()
    {
        if (PreselectedItem is not null)
            _itemSeleccionado = PreselectedItem;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_itemSeleccionado is null && !_keysRegistered)
        {
            _keysRegistered = true;
            await JS.InvokeVoidAsync("itemSelector.registerKeys", _inputRef);
        }
        else if (_itemSeleccionado is not null && !OnNavigate.HasDelegate)
        {
            _keysRegistered = false;
        }

        if (firstRender && GlobalShortcutKey is not null && !_globalShortcutRegistered && _itemSeleccionado is null)
        {
            _globalShortcutRegistered = true;
            await JS.InvokeVoidAsync("globalShortcut.register", _id, GlobalShortcutKey, _inputRef);
        }

        if (_debeScrollar && _indiceActivo >= 0)
        {
            _debeScrollar = false;
            await JS.InvokeVoidAsync("itemSelector.scrollIntoView", $"{_id}-{_indiceActivo}");
        }
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? string.Empty;
        _indiceActivo = -1;

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        if (string.IsNullOrWhiteSpace(_query))
        {
            _resultados.Clear();
            _sinResultados = false;
            _abierto = false;
            return;
        }

        _abierto = true;
        _sinResultados = false;

        if (DebounceMs > 0)
        {
            _buscando = true;
            StateHasChanged();
            try { await Task.Delay(DebounceMs, token); }
            catch (OperationCanceledException) { return; }
            if (token.IsCancellationRequested) return;
        }

        try
        {
            var items = await SearchAsync(_query, token);
            if (token.IsCancellationRequested) return;
            _resultados = items.ToList();
            _sinResultados = _resultados.Count == 0;
        }
        catch (OperationCanceledException) { }
        catch
        {
            _resultados.Clear();
            _sinResultados = false;
            _abierto = false;
        }
        finally
        {
            _buscando = false;
        }
    }

    private Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                if (!_abierto || _resultados.Count == 0) break;
                _indiceActivo = Math.Min(_indiceActivo + 1, _resultados.Count - 1);
                _debeScrollar = true;
                break;

            case "ArrowUp":
                if (!_abierto || _resultados.Count == 0) break;
                _indiceActivo = Math.Max(_indiceActivo - 1, 0);
                _debeScrollar = true;
                break;

            case "Enter":
                if (_abierto && _indiceActivo >= 0 && _indiceActivo < _resultados.Count)
                    return Seleccionar(_resultados[_indiceActivo]);
                if (_abierto && _resultados.Count == 1)
                    return Seleccionar(_resultados[0]);
                break;

            case "Escape":
                _abierto = false;
                _indiceActivo = -1;
                if (OnNavigate.HasDelegate) _query = string.Empty;
                break;
        }

        return Task.CompletedTask;
    }

    private void OnFocus()
    {
        if (_resultados.Count > 0 || _sinResultados)
            _abierto = true;
    }

    private void OnFocusOut(FocusEventArgs _)
    {
        if (_abierto)
        {
            _abierto = false;
            _indiceActivo = -1;
        }
    }

    private async Task Seleccionar(TItem item)
    {
        _abierto = false;
        _indiceActivo = -1;
        _query = string.Empty;
        _resultados.Clear();
        _sinResultados = false;

        await JS.InvokeVoidAsync("itemSelector.blur", _inputRef);

        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync(item);
        }
        else
        {
            _itemSeleccionado = item;
            await ValueChanged.InvokeAsync(GetId!(item));
        }
    }

    private async Task Limpiar()
    {
        _itemSeleccionado = default;
        _query = string.Empty;
        _resultados.Clear();
        _abierto = false;
        _indiceActivo = -1;
        _sinResultados = false;
        await ValueChanged.InvokeAsync(null);
    }

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        if (_globalShortcutRegistered)
            try { await JS.InvokeVoidAsync("globalShortcut.unregister", _id); } catch { }
    }
}
